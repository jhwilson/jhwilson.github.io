  keywords = {preprint},
  month = {nov},
  pubstate = {prepublished},
  title = {Imaging {{Self-aligned Moiré Crystals}} and {{Quasicrystals}} in {{Magic-angle Bilayer Graphene}} on {{hBN Heterostructures}}},
  url = {http://arxiv.org/abs/2311.07819},
  urldate = {2024-03-04},
