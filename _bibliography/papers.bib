  keywords = {article},
  langid = {english},
  month = {dec},
  number = {1},
  pages = {3998},
  pdf = {varnava\_controllable\_2021.pdf},
  supp = {41467\_2021\_24276\_MOESM1\_ESM.pdf},
  title = {Controllable Quantum Point Junction on the Surface of an Antiferromagnetic Topological Insulator},
  url = {http://www.nature.com/articles/s41467-021-24276-5},
